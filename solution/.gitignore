# Python
__pycache__/
*.pyc
.venv/
venv/

# Node.js
# node_modules/
# package-lock.json

# Java
# *.class
# target/
# .gradle/

# Build artifacts
# build/
# dist/
# out/

# IDE files
# .vscode/
# .idea/
